@page
@model IndexModel
@{
    ViewData["Title"] = "网络检测";
}

<div class="container py-4">
    <h1 class="mb-4">NetTester 网络检测</h1>

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        <div class="alert alert-info">@statusMessage</div>
    }

    <form method="post" asp-page-handler="SaveConfig" class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">配置</h5>
            <div class="mb-3">
                <label asp-for="IpTargetsText" class="form-label"></label>
                <textarea asp-for="IpTargetsText" class="form-control" rows="6" placeholder="每行一个 IP，支持逗号/分号分隔"></textarea>
                <div class="form-text">每行一个 IP，支持逗号/分号分隔</div>
            </div>
            <div class="mb-3">
                <label asp-for="HttpTargetsText" class="form-label"></label>
                <textarea asp-for="HttpTargetsText" class="form-control" rows="6" placeholder="每行一个 HTTP/HTTPS URL，支持逗号/分号分隔"></textarea>
                <div class="form-text">每行一个 Url，包括http://或者https://以及端口号，建议从浏览器地址栏复制</div>
            </div>
            <div class="form-check mb-2">
                <input asp-for="EnableIpProbe" class="form-check-input" />
                <label asp-for="EnableIpProbe" class="form-check-label">启用 IP 探测</label>
            </div>
            <div class="form-check mb-3">
                <input asp-for="EnableHttpProbe" class="form-check-input" />
                <label asp-for="EnableHttpProbe" class="form-check-label">启用 HTTP 探测</label>
            </div>
            <button type="submit" class="btn btn-primary">保存配置</button>
        </div>
    </form>

    <div class="mb-3 d-flex gap-2">
        <form method="post" asp-page-handler="Start">
            <input type="hidden" asp-for="IpTargetsText" />
            <input type="hidden" asp-for="HttpTargetsText" />
            <input type="hidden" asp-for="EnableIpProbe" />
            <input type="hidden" asp-for="EnableHttpProbe" />
            <button type="submit" class="btn btn-success" @(Model.IsRunning ? "disabled" : null)>启动检测</button>
        </form>
        <form method="post" asp-page-handler="Stop">
            <button type="submit" class="btn btn-secondary" @(!Model.IsRunning ? "disabled" : null)>停止检测</button>
        </form>
    </div>

    <div class="alert @(Model.IsRunning ? "alert-success" : "alert-warning")">
        当前状态：@(Model.IsRunning ? "运行中" : "已停止")
    </div>
</div>
